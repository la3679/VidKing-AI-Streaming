# ─────────────────────────────────────────────────────────────────────────────
# VidKing AI Streaming — environment configuration
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Client (exposed to the browser; VITE_ prefix required) ──────────────────

# TMDB API key (v3 auth). Get one at https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=""

# Backend API base URL. Leave empty to use same-origin "/api" (Vercel default).
# For local dev with the Express server on another port, e.g. http://localhost:8787
VITE_API_BASE_URL=""

# VidKing player origin used to validate postMessage events. Do not change
# unless VidKing changes their embed domain.
VITE_VIDKING_ORIGIN="https://www.vidking.net"

# Set to "true" to show the dev-only player diagnostics overlay.
VITE_ENABLE_PLAYER_DEBUG="false"

# Firebase web config (optional — falls back to firebase-applet-config.json).
# These values are NOT secrets; they identify the project to the browser.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""
VITE_FIREBASE_FIRESTORE_DATABASE_ID=""

# ── Server only (NEVER prefixed with VITE_, never sent to the browser) ──────

# Google Gemini API key — used exclusively by the backend AI proxy.
GEMINI_API_KEY=""

# Comma-separated list of origins allowed to call the backend (CORS).
# Example: http://localhost:3000,https://your-app.vercel.app
ALLOWED_ORIGINS="http://localhost:3000"

# Port the standalone Express server listens on during local development.
PORT="8787"
